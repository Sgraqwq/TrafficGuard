# 10. 白名单管理
whitelist_management() {
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}    全局白名单管理${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo
    
    echo -e "${BOLD}当前白名单列表:${NC}"
    if nft list set ip trafficguard whitelist >/dev/null 2>&1; then
        local wlist=$(nft list set ip trafficguard whitelist | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | xargs)
        if [ -n "$wlist" ]; then
            echo "  IP: $wlist"
        else
            echo "  (空)"
        fi
    else
        echo -e "  ${YELLOW}(白名单功能未初始化)${NC}"
    fi
    echo
    
    echo -e "${BOLD}操作:${NC}"
    echo "  1) 手动添加 IP 到白名单"
    echo "  2) 从白名单移除 IP"
    echo "  3) 自动添加当前 SSH 登录 IP 到白名单"
    echo "  4) 返回主菜单"
    echo
    read -p "请选择 [1-4]: " choice || return
    
    case $choice in
        1)
            echo
            read -p "请输入要加白的 IP 地址: " ip || return
            if [[ "$ip" =~ ^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$ ]]; then
                if nft add element ip trafficguard whitelist "{ $ip }" 2>/dev/null; then
                    echo -e "${GREEN}已将 $ip 加入全局白名单${NC}"
                else
                    echo -e "${RED}添加失败，请检查防火墙状态${NC}"
                fi
            else
                echo -e "${RED}无效的 IP 格式${NC}"
            fi
            ;;
        2)
            echo
            read -p "请输入要移除的 IP 地址: " ip || return
            if [[ "$ip" =~ ^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$ ]]; then
                if nft delete element ip trafficguard whitelist "{ $ip }" 2>/dev/null; then
                    echo -e "${GREEN}已将 $ip 从白名单中移除${NC}"
                else
                    echo -e "${RED}移除失败，该 IP 可能不在白名单中${NC}"
                fi
            else
                echo -e "${RED}无效的 IP 格式${NC}"
            fi
            ;;
        3)
            echo
            local current_ip=""
            if [ -n "${SSH_CLIENT:-}" ]; then
                current_ip=$(echo "$SSH_CLIENT" | awk '{print $1}')
            elif [ -n "${SSH_CONNECTION:-}" ]; then
                current_ip=$(echo "$SSH_CONNECTION" | awk '{print $1}')
            fi
            
            if [ -n "$current_ip" ]; then
                echo -e "检测到您当前登录的 IP 为: ${YELLOW}$current_ip${NC}"
                if nft add element ip trafficguard whitelist "{ $current_ip }" 2>/dev/null; then
                    echo -e "${GREEN}已将 $current_ip 加入全局白名单${NC}"
                else
                    echo -e "${RED}添加失败，该 IP 可能已经在白名单中，或防火墙状态异常${NC}"
                fi
            else
                echo -e "${RED}无法自动检测到当前的 SSH 登录 IP（仅支持 SSH 直连终端获取）${NC}"
            fi
            ;;
        4)
            return
            ;;
    esac
}

# 11. 完全卸载
uninstall_trafficguard() {
    echo -e "${RED}========================================${NC}"
    echo -e "${RED}    警告: 卸载 TrafficGuard${NC}"
    echo -e "${RED}========================================${NC}"
    echo -e "${YELLOW}此操作将完全卸载 TrafficGuard，并删除所有数据（不留备份）。${NC}"
    echo -e "${YELLOW}包含所有的历史流量日志、已被封禁的 IP 名单等，都会被永久销毁。${NC}"
    echo
    read -p "您确定要卸载吗？[y/N]: " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "${GREEN}已取消卸载操作。${NC}"
        return
    fi
    echo
    echo -e "${CYAN}开始卸载...${NC}"
    
    # 1. 停止定时任务
    echo -e "[-] 清理定时任务..."
    if command -v crontab >/dev/null 2>&1; then
        crontab -l 2>/dev/null | grep -v 'traffic-save-stats' | crontab - || true
    fi

    # 2. 停止 Fail2Ban
    echo -e "[-] 停止 Fail2Ban 服务..."
    systemctl stop fail2ban >/dev/null 2>&1 || true
    
    # 3. 删除 nftables 表
    echo -e "[-] 删除 nftables 规则..."
    if command -v nft >/dev/null 2>&1; then
        nft delete table ip trafficguard >/dev/null 2>&1 || true
    fi
    
    # 4. 清理 Fail2Ban 配置
    echo -e "[-] 清理 Fail2Ban 配置与数据..."
    rm -f /etc/fail2ban/jail.d/trafficguard.conf
    # 清理残留的 jail.local 规则
    if [ -f /etc/fail2ban/jail.local ]; then
        sed -i '/\[nginx-limit-req\]/,/^$/d' /etc/fail2ban/jail.local 2>/dev/null || true
        sed -i '/\[nginx-limit-conn\]/,/^$/d' /etc/fail2ban/jail.local 2>/dev/null || true
    fi
    # 尝试重启 Fail2Ban 以恢复干净状态
    systemctl start fail2ban >/dev/null 2>&1 || true

    # 5. 清理配置、数据和日志
    echo -e "[-] 删除配置、数据和日志目录..."
    rm -rf /etc/trafficguard
    rm -rf /var/lib/trafficguard
    rm -rf /var/log/trafficguard

    # 6. 删除脚本
    echo -e "[-] 删除本地脚本..."
    rm -f /usr/local/bin/traffic-save-stats
    rm -f /usr/local/bin/traffic-view-stats
    
    echo
    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}    卸载完成！${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo -e "TrafficGuard 的所有组件、规则和数据都已彻底清除。"
    
    # 最后删除自身
    rm -f /usr/local/bin/tgctl
    exit 0
}

# 1. 查看状态
show_status() {
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}    TrafficGuard 状态${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo
    
    # Fail2Ban 状态
    echo -e "${BOLD}Fail2Ban 状态:${NC}"
    if systemctl is-active --quiet fail2ban; then
        echo -e "  状态: ${GREEN}运行中${NC}"
    else
        echo -e "  状态: ${RED}未运行${NC}"
    fi
    
    # 获取 jail 列表
    local jails=$(fail2ban-client status 2>/dev/null | grep "Jail list" | cut -d: -f2 | xargs)
    if [ -n "$jails" ]; then
        echo -e "  Jails: ${GREEN}$jails${NC}"
    fi
    
    echo
    
    # nftables 状态
    echo -e "${BOLD}nftables 状态 :${NC}"
    if command -v nft >/dev/null 2>&1 && nft list table ip trafficguard >/dev/null 2>&1; then
        echo -e "  状态: ${GREEN}运行中${NC}"
    else
        echo -e "  状态: ${RED}未加载${NC}"
    fi
    
    echo
    
    # 封禁统计
    echo -e "${BOLD}封禁统计:${NC}"
    local total_banned=0
    for jail in $(fail2ban-client status 2>/dev/null | grep "Jail list" | cut -d: -f2 | tr ',' ' '); do
        jail=$(echo "$jail" | xargs)
        if [ -n "$jail" ]; then
            local banned=$(fail2ban-client status "$jail" 2>/dev/null | grep "Currently banned" | awk '{print $NF}')
            total_banned=$((total_banned + ${banned:-0}))
        fi
    done
    
    # 获取 nftables 手动封禁数量
    local manual_banned=0
    if command -v nft >/dev/null 2>&1 && nft list set ip trafficguard manual_banned >/dev/null 2>&1; then
        manual_banned=$(nft list set ip trafficguard manual_banned 2>/dev/null | grep -cE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' || true)
    fi
    
    # 确保变量格式合法，避免因为空值或包含空格导致语法错误
    total_banned=$(( ${total_banned:-0} + ${manual_banned:-0} ))
    
    echo -e "  Fail2Ban 自动封禁: ${YELLOW}$((${total_banned:-0} - ${manual_banned:-0}))${NC} 个 IP"
    echo -e "  nftables 手动黑名单: ${YELLOW}${manual_banned:-0}${NC} 个 IP"
    echo -e "  总计封禁: ${RED}${total_banned:-0}${NC} 个 IP"
    
    echo
}

