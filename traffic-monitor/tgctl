#!/usr/bin/env bash
# TrafficGuard - 命令行管理工具
# 易用、安全的流量监控和 IP 封禁管理

set -euo pipefail

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# 工具名称
TOOL_NAME="TrafficGuard"

# 检查 root 权限
check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo -e "${RED}错误: 需要 root 权限运行${NC}"
        echo "请使用: sudo tgctl"
        exit 1
    fi
}

# 检查依赖
check_deps() {
    local missing=()
    
    if ! command -v fail2ban-client >/dev/null 2>&1; then
        missing+=("fail2ban")
    fi
    
    if ! command -v nft >/dev/null 2>&1; then
        missing+=("nftables")
    fi
    
    if ! command -v nginx >/dev/null 2>&1; then
        missing+=("nginx")
    fi
    
    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${RED}错误: 缺少依赖${NC}"
        echo "缺少: ${missing[*]}"
        echo "请先运行安装脚本: sudo bash scripts/install.sh"
        exit 1
    fi
}

