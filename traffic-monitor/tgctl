# 3. 封禁 IP
ban_ip() {
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}    封禁 IP${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo
    
    # 选择 jail
    echo -e "${BOLD}选择要封禁的类型:${NC}"
    echo "  1) 全局黑名单 (基于 nftables, 封禁所有端口)"
    echo "  2) SSH 防护 (仅封禁 SSH 端口)"
    echo "  3) 全部"
    echo
    read -p "请选择 [1-3]: " choice || return
    
    # 输入 IP
    echo
    read -p "请输入要封禁的 IP 地址: " ip || return
    
    # 验证 IP 格式
    if ! [[ "$ip" =~ ^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$ ]]; then
        echo -e "${RED}无效的 IP 地址格式${NC}"
        return
    fi
    
    # 确认
    echo
    read -p "确定要封禁 $ip 吗? (y/n): " confirm || return
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "${YELLOW}已取消${NC}"
        return
    fi
    
    # 执行封禁
    if [[ "$choice" == "1" || "$choice" == "3" ]]; then
        if nft add element ip trafficguard manual_banned "{ $ip }" 2>/dev/null; then
            echo -e "${GREEN}已封禁 $ip (全局黑名单)${NC}"
        else
            echo -e "${RED}封禁失败: $ip (全局黑名单)${NC}"
        fi
    fi
    
    if [[ "$choice" == "2" || "$choice" == "3" ]]; then
        if fail2ban-client set sshd banip "$ip" 2>/dev/null; then
            echo -e "${GREEN}已封禁 $ip (SSH 防护)${NC}"
        else
            echo -e "${RED}封禁失败: $ip (SSH 防护)${NC}"
        fi
    fi
}

