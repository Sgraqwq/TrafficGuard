# 检查 root 权限
check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo -e "${RED}错误: 需要 root 权限运行${NC}"
        echo "请使用: sudo /usr/local/bin/tgctl"
        exit 1
    fi
}

# 检查依赖
check_deps() {
    local missing=()
    
    if ! command -v fail2ban-client >/dev/null 2>&1; then
        missing+=("fail2ban")
    fi
    
    if ! command -v nft >/dev/null 2>&1; then
        missing+=("nftables")
    fi
    

    
    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${RED}错误: 缺少依赖${NC}"
        echo "缺少: ${missing[*]}"
        echo "请先运行安装脚本: sudo bash scripts/install.sh"
        exit 1
    fi
}

