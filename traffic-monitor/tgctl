# 安全配置读取
get_config_int() {
    local key="$1"
    local file="$2"
    local default_val="${3:-0}"
    if [ -f "$file" ]; then
        local val
        val=$(grep -E "^${key}=" "$file" 2>/dev/null | head -n1 | cut -d= -f2- | grep -oE '[0-9]+' | head -n1)
        if [ -n "$val" ]; then
            echo "$val"
            return
        fi
    fi
    echo "$default_val"
}

