# 快速封禁 IP（非交互式）
quick_ban_ip() {
    local ip="$1"
    if ! [[ "$ip" =~ ^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$ ]]; then
        echo -e "${RED}无效的 IP 地址格式: $ip${NC}"
        exit 1
    fi
    for jail in nginx-limit-req nginx-limit-conn sshd; do
        if fail2ban-client set "$jail" banip "$ip" 2>/dev/null; then
            echo -e "${GREEN}已封禁 $ip (jail: $jail)${NC}"
        else
            echo -e "${RED}封禁失败: $ip (jail: $jail)${NC}"
        fi
    done
}

# 快速解封 IP（非交互式）
quick_unban_ip() {
    local ip="$1"
    if ! [[ "$ip" =~ ^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$ ]]; then
        echo -e "${RED}无效的 IP 地址格式: $ip${NC}"
        exit 1
    fi
    for jail in nginx-limit-req nginx-limit-conn sshd; do
        if fail2ban-client set "$jail" unbanip "$ip" 2>/dev/null; then
            echo -e "${GREEN}已解封 $ip (jail: $jail)${NC}"
        else
            echo -e "${RED}解封失败: $ip (jail: $jail)${NC}"
        fi
    done
}

# 11. 检查更新
check_update() {
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}    检查更新${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo
    
    echo -e "${BOLD}当前版本: ${GREEN}$TG_VERSION${NC}"
    echo
    
    echo -e "${BOLD}正在检查更新...${NC}"
    
    # 检查网络连接
    if ! curl -s --connect-timeout 5 --max-time 10 "https://github.com" >/dev/null 2>&1; then
        echo -e "${RED}无法连接到 GitHub，请检查网络${NC}"
        return 1
    fi
    
    # 获取最新版本号（从 common.sh 中提取）
    local latest_version
    latest_version=$(curl -s --connect-timeout 10 --max-time 30 "${TG_REPO}/raw/main/scripts/lib/common.sh" 2>/dev/null | grep -oP 'TG_VERSION="\K[^"]+' || true)
    
    if [ -z "$latest_version" ]; then
        echo -e "${RED}无法获取最新版本信息${NC}"
        return 1
    fi
    
    echo -e "${BOLD}最新版本: ${GREEN}$latest_version${NC}"
    echo
    
    # 比较版本
    if [ "$latest_version" = "$TG_VERSION" ]; then
        echo -e "${GREEN}✓ 已是最新版本${NC}"
        return 0
    fi
    
    echo -e "${YELLOW}发现新版本: $TG_VERSION → $latest_version${NC}"
    echo
    echo -e "${BOLD}更新内容:${NC}"
    echo "  1) 下载最新安装脚本"
    echo "  2) 重新安装 TrafficGuard"
    echo
    read -p "是否立即更新? [y/N]: " confirm || return
    
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "${YELLOW}已取消更新${NC}"
        return 0
    fi
    
    echo
    echo -e "${CYAN}开始更新...${NC}"
    
    # 下载最新安装脚本
    local tmp_script
    tmp_script=$(mktemp /tmp/tg_install_XXXXXX.sh)
    
    if ! curl -fsSL --connect-timeout 10 --max-time 60 "${TG_REPO}/raw/main/scripts/install.sh" -o "$tmp_script" 2>/dev/null; then
        echo -e "${RED}下载安装脚本失败${NC}"
        rm -f "$tmp_script"
        return 1
    fi
    
    echo -e "${GREEN}下载完成，开始安装...${NC}"
    echo
    
    # 执行安装脚本
    chmod +x "$tmp_script"
    exec sudo bash "$tmp_script"
}

# 主函数
main() {
    check_root
    check_deps

    # 命令行参数分发
    if [ $# -gt 0 ]; then
        case "$1" in
            status)   show_status ;;
            list)     show_ban_list ;;
            ban)
                if [ -z "${2:-}" ]; then
                    echo -e "${RED}错误: 请指定要封禁的 IP 地址${NC}"
                    echo "用法: tgctl ban <IP>"
                    exit 1
                fi
                quick_ban_ip "$2"
                ;;
            unban)
                if [ -z "${2:-}" ]; then
                    echo -e "${RED}错误: 请指定要解封的 IP 地址${NC}"
                    echo "用法: tgctl unban <IP>"
                    exit 1
                fi
                quick_unban_ip "$2"
                ;;
            traffic)  show_traffic ;;
            history)  show_history_traffic ;;
            ssh)      ssh_protection ;;
            config)   config_management ;;
            service)  service_management ;;
            update)   check_update ;;
            version)
                echo -e "TrafficGuard 版本: ${GREEN}$TG_VERSION${NC}"
                ;;
            help|-h|--help) show_usage ;;
            *)
                echo -e "${RED}未知命令: $1${NC}"
                show_usage
                exit 1
                ;;
        esac
        exit 0
    fi

    # 无参数时进入交互式菜单
    while true; do
        show_logo
        show_menu
        
        read -p "请选择 [0-12]: " choice || { echo; echo -e "${GREEN}再见！${NC}"; exit 0; }
        
        case $choice in
            1) show_status ;;
            2) show_ban_list ;;
            3) ban_ip ;;
            4) unban_ip ;;
            5) show_traffic ;;
            6) show_history_traffic ;;
            7) ssh_protection ;;
            8) config_management ;;
            9) service_management ;;
            10) whitelist_management ;;
            11) check_update ;;
            12) uninstall_trafficguard ;;
            0)
                echo -e "${GREEN}再见！${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}无效选择${NC}"
                ;;
        esac
    done
}

# 运行主函数
main "$@"
