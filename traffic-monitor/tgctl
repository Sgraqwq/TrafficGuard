# 6. SSH 防护
ssh_protection() {
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}    SSH 防护${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo
    
    # SSH jail 状态
    echo -e "${BOLD}SSH 防护状态:${NC}"
    if fail2ban-client status sshd >/dev/null 2>&1; then
        echo -e "  状态: ${GREEN}已启用${NC}"
        fail2ban-client status sshd 2>/dev/null | grep -E "Currently banned|Total banned|Banned IP list" | sed 's/^/  /'
    else
        echo -e "  状态: ${YELLOW}未启用${NC}"
    fi
    
    echo
    
    # SSH 连接信息
    echo -e "${BOLD}当前 SSH 连接:${NC}"
    who | head -10
    echo
    
    # 最近登录
    echo -e "${BOLD}最近登录:${NC}"
    last -n 5 2>/dev/null | head -5
    echo
    
    # SSH 配置建议
    echo -e "${BOLD}安全建议:${NC}"
    echo "  1. 使用密钥登录，禁用密码登录"
    echo "  2. 修改默认 SSH 端口"
    echo "  3. 启用 Fail2Ban SSH jail"
    echo
    
    # 操作选项
    echo -e "${BOLD}操作:${NC}"
    echo "  1) 查看 SSH 日志"
    echo "  2) 封禁可疑 IP"
    echo "  3) 返回主菜单"
    echo
    read -p "请选择 [1-3]: " choice || return
    
    case $choice in
        1)
            echo
            echo -e "${BOLD}最近 SSH 失败登录:${NC}"
            grep "Failed password" /var/log/auth.log 2>/dev/null | tail -10 || echo "无法读取日志"
            echo
            echo -e "${YELLOW}按回车返回...${NC}"
            read || true
            ;;
        2)
            echo
            read -p "请输入要封禁的 IP: " ip || return
            if [[ "$ip" =~ ^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$ ]]; then
                if fail2ban-client set sshd banip "$ip" 2>/dev/null; then
                    echo -e "${GREEN}已封禁 $ip${NC}"
                else
                    echo -e "${RED}封禁失败${NC}"
                fi
            else
                echo -e "${RED}无效的 IP 地址${NC}"
            fi
            echo
            echo -e "${YELLOW}按回车返回...${NC}"
            read || true
            ;;
        3)
            return
            ;;
        *)
            echo -e "${RED}无效选择${NC}"
            echo -e "${YELLOW}按回车返回...${NC}"
            read || true
            ;;
    esac
}

# 7. 配置管理
config_management() {
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}    配置管理${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo
    
    echo -e "${BOLD}配置文件:${NC}"
    echo "  [Fail2Ban 防护] /etc/fail2ban/jail.d/trafficguard.conf"
    echo "  [内核限流防护]  /etc/trafficguard/trafficguard.conf"
    echo
    
    echo -e "${BOLD}操作:${NC}"
    echo "  1) 查看 Fail2Ban 配置"
    echo "  2) 编辑 Fail2Ban 配置"
    echo "  3) 重载 Fail2Ban"
    echo "  4) 查看 防火墙内核限流配置"
    echo "  5) 编辑 防火墙内核限流配置"
    echo "  6) 重载 防火墙内核规则 (无缝生效)"
    echo "  7) 返回主菜单"
    echo
    read -p "请选择 [1-7]: " choice || return
    
    case $choice in
        1)
            echo
            echo -e "${BOLD}Fail2Ban 配置:${NC}"
            cat /etc/fail2ban/jail.d/trafficguard.conf 2>/dev/null || echo "配置不存在"
            echo
            ;;
        2)
            echo
            if command -v nano >/dev/null 2>&1; then
                nano /etc/fail2ban/jail.d/trafficguard.conf
            elif command -v vi >/dev/null 2>&1; then
                vi /etc/fail2ban/jail.d/trafficguard.conf
            else
                echo -e "${RED}未找到编辑器 (nano/vi)${NC}"
            fi
            ;;
        3)
            echo
            echo -e "${BOLD}重载配置...${NC}"
            systemctl reload fail2ban
            echo -e "${GREEN}Fail2Ban 配置已重载${NC}"
            echo
            ;;
        4)
            echo
            echo -e "${BOLD}内核限流配置:${NC}"
            cat /etc/trafficguard/trafficguard.conf 2>/dev/null || echo "配置不存在"
            echo
            ;;
        5)
            echo
            if command -v nano >/dev/null 2>&1; then
                nano /etc/trafficguard/trafficguard.conf
            elif command -v vi >/dev/null 2>&1; then
                vi /etc/trafficguard/trafficguard.conf
            else
                echo -e "${RED}未找到编辑器 (nano/vi)${NC}"
            fi
            ;;
        6)
            echo
            echo -e "${BOLD}正在平滑重载防火墙规则...${NC}"
            local tg_conf="/etc/trafficguard/trafficguard.conf"
            if [ -f "$tg_conf" ]; then
                # 安全解析配置
                local TG_CONN_LIMIT
                TG_CONN_LIMIT=$(get_config_int "TG_CONN_LIMIT" "$tg_conf" "0")
                local TG_RATE_LIMIT
                TG_RATE_LIMIT=$(get_config_int "TG_RATE_LIMIT" "$tg_conf" "0")
                local TG_RATE_BURST
                TG_RATE_BURST=$(get_config_int "TG_RATE_BURST" "$tg_conf" "100")
                
                # 更新并发限制
                for handle in $(nft -a list chain ip trafficguard TRAFFICGUARD 2>/dev/null | grep 'ct count over' | awk '{print $NF}'); do
                    nft delete rule ip trafficguard TRAFFICGUARD handle "$handle" 2>/dev/null || true
                done
                
                if [ "$TG_CONN_LIMIT" -gt 0 ]; then
                    nft add rule ip trafficguard TRAFFICGUARD ct state new add @conn_limit { ip saddr ct count over ${TG_CONN_LIMIT} } drop 2>/dev/null || echo -e "${RED}更新并发限制失败${NC}"
                fi
                
                # 更新频率限制
                for handle in $(nft -a list chain ip trafficguard TRAFFICGUARD 2>/dev/null | grep 'limit rate over' | awk '{print $NF}'); do
                    nft delete rule ip trafficguard TRAFFICGUARD handle "$handle" 2>/dev/null || true
                done
                
                if [ "$TG_RATE_LIMIT" -gt 0 ]; then
                    nft add rule ip trafficguard TRAFFICGUARD ct state new update @rate_limit { ip saddr limit rate over ${TG_RATE_LIMIT}/second burst ${TG_RATE_BURST} packets } drop 2>/dev/null || echo -e "${RED}更新频率限制失败${NC}"
                fi
                
                echo -e "${GREEN}底层防火墙限流规则重载完成！无任何现存连接断开。${NC}"
            else
                echo -e "${RED}配置文件 /etc/trafficguard/trafficguard.conf 不存在！${NC}"
            fi
            echo
            ;;
        7)
            return
            ;;
    esac
}

